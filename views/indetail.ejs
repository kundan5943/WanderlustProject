
<% layout('./layouts/boilerplate.ejs') -%>
<body>
     
      <div class="col-10 offset-3 shw">
      
          <h3 style="margin-left: 20px; margin-top: 10px;"><%=data.title%></h3>
<div class="card col-6 " >
  <img src="<%=data.image%>" class="card-img-top shw-img" alt="...">
  <div class="card-body">
     <%if(data.owner){%>
     <p class="card-text" style="margin-top: 5px;"><b>Owned by:</b><%=data.owner.username%></p>
       <%}%>
     <p class="card-text" style="margin-top: 5px;"><b>Description:</b><%=data.description%></p>
      <p class="card-text"><b>Price:</b><%=data.price%></p>
       <p class="card-text"><b>Location:</b><%=data.location %></p>
        <p class="card-text"><b>Country:</b><%=data.country%></p>

     <%if(data.owner&&currUser){%>
     <%if(data.owner._id.equals(currUser._id)){%>
       <form style="display: inline-block;"  action="/wanderlust/edit/<%=data._id%>" method="get">
               <button class="btn btn-primary addbtn" type="submit">Edit</button>
              
          </form>

           <form style="display: inline-block;" action="/wanderlust/delete/<%=data._id%>?_method=delete" method="post" >
            
            <button class="btn btn-primary addbtn" type="submit">Delete</button>
          </form>
   <%}%>
     <%}%>

  </div>
</div>

</div>
 <hr>
<div class="col-md-6 offset-3" style="margin-bottom: 10px;">


  <!-- Add review -->
     <%if(currUser){%>
  <div class="needs-validation" novalidate>
  <h3>Add review</h3>
     
     <form action="/wanderlust/review/<%=data._id%>/addReview" method="post"  class="needs-validation" novalidate>
      <label class="form-label" for="rvw" >Rating</label>
      <input  class="form-control" type="range" min="1" max="5" name="rating" id="rvw"  required type="range">
      <br>
      <div>
      <label class="form-label" for="cmnt">Comment</label>
      <textarea class="form-control" type="text" name="comment" id="cmnt" required ></textarea>
      <div class="invalid-feedback">
      Please provide a valid Comment
    </div>
     <div class="valid-feedback">
      Looks good!
    </div>
      </div>
      <br>
      <button type="submit " style="color: white;" class="btn btn-Secondary addbtn ">Submit</button>
     </form>
</div>
<%}%>
</div>
<div style="margin-bottom: 10px; margin-top: 10px;">
  <div class="col-md-6 offset-3">
    <h3 >All Reviews</h3>
  </div>
  <div class="col-md-10 offset-2 rvwcards">

<%let n=1%>
 <% for(let review of data.reviews){%>
         
       <div class="card " style="width: 15rem; ">
  <div class="card-body">
    <h5 class="card-title">@<%=review.author.username%></h5>
    <h6 class="card-subtitle mb-2 text-body-secondary">
      rating: <%=review.rating%>
    </h6>
    
    <p class="card-text"><%=review.comment%></p>
       <%if(currUser){%>
      <%if(review.author.equals(currUser._id)){%>
     <form method="post" action="/wanderlust/review/<%=data._id%>/<%=review._id%>/deletereview?_method=Delete">
      <button class="btn btn-Secondary addbtn " type="submit">Delete</button>
     </form>
      <%}%>
       <%}%>
</div>
</div>
 <% }%>
    
</div>
</div>
</body>
