<% layout('/layouts/boilerplate.ejs')-%>
<body>
     <div class="nwform">
       
        <div class="col-6 offset-3">
             <H3>Login</H3>
   <form class="row g-0.5 needs-validation" novalidate method="post" action="/wanderlust/authenticate/login">
  

   <label for="usrname" class="form-label">Username</label>
    <input  class="form-control" name="username" id="usrname" type="text">
    <div class="invalid-feedback">
      Please provide a valid Username.
    </div>
     <div class="valid-feedback">
      Looks good!
    </div>
  
    
  <label for="password" class="form-label">Password</label>
    <input type="password" class="form-control" name="password" id="password" type="text">
    <div class="invalid-feedback">
      Please provide a valid Password.
    </div>
     <div class="valid-feedback">
      Looks good!
    </div>

  
  <div style="margin-top: 10px;" class="col-3">
    <button type="submit" class="btn btn-primary addbtn">Login</button>
  </div>
 </div>
</form>
 </div>
</div>
</body>
