<% layout('./layouts/boilerplate.ejs') -%>
<body>
    
      <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1" >
        <%for(let dta of data ){%>
            <a class="listing-links" href="/wanderlust/indetail/<%=dta._id%>">

            <div class="card col" style="width: 25rem;">
            <img src="<%=dta.image.url%>" class="card-img-top" alt="...">
             <div class="card-img-overlay"></div>
            <div class="card-body">
                <p class="card-text"><b><%=dta.title%> </b><br>
                               &#8377;<%= dta.price ? dta.price.toLocaleString("en-IN") : "N/A" %>/night
                               &nbsp; <i class="gst">+18%Gst</i>
                           
</p>
            </div>
            </div>
            </a>
        <%}%>
   </div>
   
</body>

</div>

